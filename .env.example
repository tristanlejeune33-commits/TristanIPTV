# Pre-fill the M3U URL for every visitor.
#
# When set, the /api/m3u-url endpoint returns this URL as the default. Any
# device opening the app for the first time (no localStorage value yet) will
# auto-load this playlist — no need to paste the link manually on the TV,
# iPhone, or another browser.
#
# Set this on Vercel via "Project Settings → Environment Variables" or
# locally in a `.env.local` file (gitignored).
#
# Example:
# DEFAULT_M3U_URL=http://your-iptv-provider.example.com/get.php?username=...&password=...&type=m3u
DEFAULT_M3U_URL=

# Server-side filtering of the M3U playlist. Crucial when your provider
# ships a huge bouquet (the original user has a 136 MB playlist!) that no
# mobile client could ever download in reasonable time.
#
# Both lists are comma-separated, case-insensitive, matched against the
# #EXTINF line (channel name + group-title). Set them on Vercel via
# "Project Settings → Environment Variables".
#
# Keep only entries containing at least one of these keywords:
# M3U_INCLUDE=FR,francais,france,french,VF,VOSTFR,MULTI
#
# Drop entries containing any of these keywords. Defaults to a sensible
# adult-content blacklist if not set:
# M3U_EXCLUDE=XXX,porn,adult,18+

# Optional secret to protect /api/cron/warm. When set, Vercel's cron sends
# Authorization: Bearer <secret> automatically. External cron services
# (cron-job.org, etc.) need to send the same header.
CRON_SECRET=
